# Copy this file to .env and adjust values for your environment.
# Docker Compose automatically reads .env from the project root.

# Required when running Django outside Docker. In Docker, entrypoint.sh can generate
# and persist .secret_key automatically if SECRET_KEY is empty.
SECRET_KEY=change-me-generate-with-django-get_random_secret_key

# Site settings
FRONTEND_HOST=http://localhost
PORTAL_NAME=MediaCMS
DEBUG=False

# Database settings used by deploy/docker/local_settings.py
POSTGRES_NAME=mediacms
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=mediacms
POSTGRES_PASSWORD=mediacms

# Redis / Celery cache broker
REDIS_LOCATION=redis://redis:6379/1

# Local development webpack dev server
WEBPACK_DEV_SERVER_URL=http://localhost:8088

# Initial admin user created by migrations/prestart on a fresh database
ADMIN_USER=admin
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=change-me

# Build/deploy toggles
ENABLE_COLLECTSTATIC=yes
ENABLE_MIGRATIONS=yes
ENABLE_UWSGI=yes
ENABLE_NGINX=yes
ENABLE_CELERY_SHORT=yes
ENABLE_CELERY_LONG=yes
ENABLE_CELERY_BEAT=yes
ENABLE_REQUIREMENTS_SYNC=no
REQUIREMENTS_SYNC_FILES=requirements.txt
REQUIREMENTS_SYNC_MARKER=/home/mediacms.io/.requirements-sync.sha256
CHOWN_PROJECT_TREE=no
CHOWN_PATHS=/home/mediacms.io/mediacms/logs /home/mediacms.io/mediacms/media_files /var/run/mediacms

# AI transcription / analysis settings
USE_WHISPER_TRANSCRIBE=True
WHISPER_MODEL=medium
WHISPER_BIN=/home/mediacms.io/bin/whisper
DASHSCOPE_API_KEY=
APPROVAL_REVIEWER=admin
IP_WHITELIST=

# Optional: override where Docker-generated SECRET_KEY is stored
SECRET_KEY_FILE=/home/mediacms.io/mediacms/.secret_key
